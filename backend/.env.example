# ---------------------------------------------------------------------------
# MediCall AI - Environment Configuration
# Copy this file to ".env" and fill in real values.
# The app is designed to run in SIMULATION MODE with no external keys set.
# ---------------------------------------------------------------------------

# --- Database ---
# Local Postgres (docker-compose default). Swap for a Supabase URL when ready:
# postgresql://postgres:<password>@<project>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medicall_ai

# --- App ---
APP_ENV=development
APP_NAME=MediCall AI
API_V1_PREFIX=/api

# --- OpenAI (LLM classification + embeddings) ---
# Leave blank to run with the built-in rule-based fallback classifier
# and the local (no-key) embedding model for RAG.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Gemini (live conversational AI over Twilio ConversationRelay) ---
# Leave blank to keep the single-question <Gather> call flow. Set this to
# enable a real multi-turn spoken conversation instead (see
# app/services/conversation_service.py). Get a key at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Twilio (real outbound voice calls - optional for MVP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PUBLIC_BASE_URL=https://your-public-domain.example.com

# FastAPI's own base URL, as seen by n8n (inside docker-compose this is
# http://backend:8000; n8n uses it to call the pending-calls/mark-call-*
# endpoints). PUBLIC_BASE_URL above is the externally-reachable tunnel URL
# Twilio itself uses for TwiML/webhooks - the two are NOT the same thing.
FASTAPI_BASE_URL=http://localhost:8000

# --- Owner notification email ---
OWNER_EMAIL=owner@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- RAG / vector store ---
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION_NAME=pharmacy_policies

# --- Manual kill-switches ---
# Force-disable real Twilio calls / real LLM calls even if credentials above
# are present. Leave at "true" normally; default is "true" if unset.
TWILIO_ENABLED=true
AI_ENABLED=true

# --- n8n (automation workflow layer - see backend/n8n/n8n-setup-guide.md) ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
